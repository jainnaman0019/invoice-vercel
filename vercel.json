{
    "version": 2,
    "routes": [
      { "src": "/api/(.*)", "dest": "api/index.js" },
  
      {
        "src": "/assets/(.*)",
        "dest": "/fronte/billing-frontend/dist/assets/$1"
      },
  
      {
        "src": "/(.*)",
        "dest": "/fronte/billing-frontend/dist/index.html"
      }
    ]
  }