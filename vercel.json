{
    "version": 2,
    "builds": [
      { "src": "api/index.js", "use": "@vercel/node" },
      {
        "src": "fronte/billing-frontend/package.json",
        "use": "@vercel/static-build",
        "config": { "distDir": "dist" }
      }
    ],
    "routes": [
      { "src": "/", "dest": "/dashboard" },   
      { "src": "/api/(.*)", "dest": "api/index.js" },
      { "src": "/(.*)", "dest": "fronte/billing-frontend/dist/$1" }
    ]
  }