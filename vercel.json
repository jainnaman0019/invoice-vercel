{
    "version": 2,
    "builds": [
      { "src": "api/index.js", "use": "@vercel/node" },
      {
        "src": "fronte/billing-frontend/package.json",
        "use": "@vercel/static-build",
        "config": { "distDir": "dist" }
      }
    ],
    "routes": [
      { "src": "/api/(.*)", "dest": "api/index.js" },
      { "handle": "filesystem" },
      {
        "src": "/(.*)",
        "dest": "fronte/billing-frontend/dist/index.html"
      }
    ]
  }