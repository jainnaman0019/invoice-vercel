{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/fronte/billing-frontend/assets/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/fronte/billing-frontend/index.html"
    }
  ]
}